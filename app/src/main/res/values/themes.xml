<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Launcher splash theme. Compose takes over inside MainActivity. -->
    <!-- Dark background prevents any white flash before Compose renders. -->
    <style name="Theme.Triledge" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>